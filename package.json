{
  "name": "kinova-bot",
  "version": "1.0.0",
  "description": "Telegram bot for movie identification from screenshots",
  "main": "dist/bot.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && cp src/dashboard/dashboardClient.js dist/dashboard/dashboardClient.js",
    "start": "node dist/bot.js",
    "dev": "ts-node src/bot.ts",
    "watch": "nodemon --exec ts-node src/bot.ts",
    "dashboard": "npm run build && node dist/dashboard/entry.js",
    "dashboard:dev": "ts-node src/dashboard/entry.ts",
    "dashboard:next": "npm --prefix startup run dev",
    "dashboard:next:build": "npm --prefix startup run build",
    "test": "jest --verbose --selectProjects unit --forceExit",
    "test:startup": "npm --prefix startup test",
    "test:integration": "jest --verbose --selectProjects integration --forceExit",
    "test:all": "jest --verbose --forceExit",
    "test:watch": "jest --watch --selectProjects unit",
    "migrate:sqlite": "ts-node --transpile-only scripts/migrate-sqlite-to-pg.ts"
  },
  "dependencies": {
    "@aws-sdk/client-rekognition": "^3.750.0",
    "@google/generative-ai": "^0.21.0",
    "@grammyjs/runner": "^2.0.3",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.20.0",
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "grammy": "^1.34.0",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.33.5",
    "typescript": "^5.7.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/jest": "^30.0.0",
    "@types/qrcode": "^1.5.6",
    "better-sqlite3": "^11.8.1",
    "jest": "^30.3.0",
    "nodemon": "^3.1.9",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2"
  }
}
