BOT_TOKEN=
GEMINI_API_KEY=
TMDB_API_KEY=
OMDB_API_KEY=
SERPER_API_KEY=
VISION_API_KEY=
IMGBB_API_KEY=

# AWS Rekognition (ixtiyoriy)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Neon / Vercel Postgres — analytics (ixtiyoriy)
DATABASE_URL=

# Gemini tartib va burst (ixtiyoriy, default ishlaydi)
# GEMINI_MAX_CONCURRENT=8
# GEMINI_MIN_GAP_MS=70
# GEMINI_MAX_RETRIES=4

# Rasm limitlari (ixtiyoriy)
# PHOTO_BURST_WINDOW_SECONDS=900
# PHOTO_BURST_LIMIT=6
# PHOTO_DAILY_LIMIT=80

UNLIMITED_TELEGRAM_IDS=

# Web dashboard — alohida jarayon: npm run dashboard (prod: npm run build && npm run dashboard)
# Bot bilan bir vaqtda emas; bir xil .env va SQLite/DB fayllarini ko‘rishi kerak
DASHBOARD_USER=
DASHBOARD_PASSWORD=
# Kamida 32 belgi tavsiya etiladi
DASHBOARD_SESSION_SECRET=
# Dashboard logo: logos/ ichidagi fayl nomi (default: Untitled-1-02.png)
# DASHBOARD_LOGO_FILE=Untitled-1-02.png
