BOT_TOKEN=
GEMINI_API_KEY=
TMDB_API_KEY=
OMDB_API_KEY=
BRAVE_SEARCH_API_KEY=
VISION_API_KEY=
IMGBB_API_KEY=

# AWS Rekognition (ixtiyoriy)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Neon Postgres — majburiy (bot va dashboard)
DATABASE_URL=

# Ha/Yo‘q analytics: saqlangan rasm (base64) — faqat so‘nggi N kun; keyin metadata dan olib tashlanadi
# FEEDBACK_THUMB_RETENTION_DAYS=30
# To‘liq feedback qatori (identification_feedback) M kundan keyin o‘chiriladi (M ≥ N)
# FEEDBACK_ANALYTICS_RETENTION_DAYS=90

# Bir martalik SQLite → Postgres: npm run migrate:sqlite -- ./kinova.db
# SQLITE_MIGRATE_PATH=

# Gemini tartib va burst (ixtiyoriy, default ishlaydi)
# GEMINI_MAX_CONCURRENT=8
# GEMINI_MIN_GAP_MS=70
# GEMINI_MAX_RETRIES=4
# Matnli syujet qidiruvida Google Search grounding (pulli)
# GEMINI_GROUNDING_TEXT_SEARCH=false

# Matn qidiruv (ixtiyoriy; default 6 ta / 12 soat)
# USER_REQUEST_LIMIT=6

# Rasm limitlari (ixtiyoriy)
# PHOTO_BURST_WINDOW_SECONDS=900
# PHOTO_BURST_LIMIT=5
# PHOTO_DAILY_LIMIT=50

# Instagram Reels va YouTube havola (bir xil limit; ixtiyoriy; default 2 ta / 6 soat)
# REELS_WINDOW_SECONDS=21600
# REELS_LIMIT_PER_WINDOW=2
# REELS_MAX_DOWNLOAD_MB=80
# REELS_DOWNLOAD_TIMEOUT_MS=90000
# REELS_FFMPEG_TIMEOUT_MS=45000
# YT_DLP_PATH=yt-dlp
# FFMPEG_PATH=ffmpeg
#
# macOS (brew ishlamasa ham): yt-dlp_macos + evermeet ffmpeg — bir skript
#   bash scripts/install-reels-tools-macos.sh

# Parallel yangilanishlar (faqat long polling + @grammyjs/runner). Kamaytirish: Gemini 429 kamayishi mumkin.
# BOT_CONSUMER_CONCURRENCY=100

UNLIMITED_TELEGRAM_IDS=

# Admin: /donate → tasdiq → barcha userlarga so‘rovnoma (test: faqat N ta)
# SURVEY_BROADCAST_MAX_RECIPIENTS=30

# Ixtiyoriy donate (ixtiyoriy; yoqish uchun DONATE_ENABLED=true va karta raqami kerak)
# DONATE_ENABLED=false
# DONATE_CARD_NUMBER=
# DONATE_CARDHOLDER=
# DONATE_PAYME_URL=
# DONATE_NOTE=
# DONATE_COOLDOWN_DAYS=14
# «Ha» bo‘yicha: birinchi ~4 ta, keyin oraliqlar keng (default 4,12,28,60)
# DONATE_FEEDBACK_MILESTONES=4,12,28,60
# DONATE_SUCCESS_MILESTONES=20,60,150

# Web dashboard — alohida jarayon: npm run dashboard (prod: npm run build && npm run dashboard)
# Next.js admin (startup/): npm run dashboard:next — startup/.env.example ga qarang
# Bot bilan bir vaqtda emas; bir xil .env (DATABASE_URL) kerak
# Jadvaldagi screenshot ustunlari uchun Telegram orqali rasm ko‘rinishi: BOT_TOKEN ham shu .env da bo‘lishi kerak
DASHBOARD_USER=
DASHBOARD_PASSWORD=
# Kamida 32 belgi tavsiya etiladi
DASHBOARD_SESSION_SECRET=
# Dashboard logo: logos/ ichidagi fayl nomi (default: Untitled-1-02.png)
# DASHBOARD_LOGO_FILE=Untitled-1-02.png
