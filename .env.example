BOT_TOKEN=
GEMINI_API_KEY=
TMDB_API_KEY=
OMDB_API_KEY=
SERPER_API_KEY=
VISION_API_KEY=
IMGBB_API_KEY=

# AWS Rekognition (ixtiyoriy)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Neon Postgres — majburiy (bot va dashboard)
DATABASE_URL=

# Bir martalik SQLite → Postgres: npm run migrate:sqlite -- ./kinova.db
# SQLITE_MIGRATE_PATH=

# Gemini tartib va burst (ixtiyoriy, default ishlaydi)
# GEMINI_MAX_CONCURRENT=8
# GEMINI_MIN_GAP_MS=70
# GEMINI_MAX_RETRIES=4

# Rasm limitlari (ixtiyoriy)
# PHOTO_BURST_WINDOW_SECONDS=900
# PHOTO_BURST_LIMIT=6
# PHOTO_DAILY_LIMIT=80

# Instagram Reels (ixtiyoriy; default 2 ta / 6 soat)
# REELS_WINDOW_SECONDS=21600
# REELS_LIMIT_PER_WINDOW=2
# REELS_MAX_DOWNLOAD_MB=80
# REELS_DOWNLOAD_TIMEOUT_MS=90000
# REELS_FFMPEG_TIMEOUT_MS=45000
# YT_DLP_PATH=yt-dlp
# FFMPEG_PATH=ffmpeg
#
# macOS (brew ishlamasa ham): yt-dlp_macos + evermeet ffmpeg — bir skript
#   bash scripts/install-reels-tools-macos.sh

UNLIMITED_TELEGRAM_IDS=

# Web dashboard — alohida jarayon: npm run dashboard (prod: npm run build && npm run dashboard)
# Bot bilan bir vaqtda emas; bir xil .env (DATABASE_URL) kerak
DASHBOARD_USER=
DASHBOARD_PASSWORD=
# Kamida 32 belgi tavsiya etiladi
DASHBOARD_SESSION_SECRET=
# Dashboard logo: logos/ ichidagi fayl nomi (default: Untitled-1-02.png)
# DASHBOARD_LOGO_FILE=Untitled-1-02.png
